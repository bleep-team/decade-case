{
  "name": "@decade/auth",
  "version": "0.0.1",
  "private": true,
  "description": "Clerk authentication helpers and broker identity context",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.0.0"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@decade/eslint-config": "workspace:*",
    "@decade/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
