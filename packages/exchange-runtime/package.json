{
  "name": "@decade/exchange-runtime",
  "version": "0.0.1",
  "private": true,
  "description": "Inngest jobs: per-symbol matching, order-expiry sweep, and webhook delivery",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@decade/db": "workspace:*",
    "@decade/logger": "workspace:*",
    "@decade/matching-engine": "workspace:*",
    "@decade/types": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "inngest": "^3.0.0"
  },
  "devDependencies": {
    "@decade/eslint-config": "workspace:*",
    "@decade/typescript-config": "workspace:*",
    "@electric-sql/pglite": "^0.5.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
