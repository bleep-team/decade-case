{
  "name": "@decade/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript domain primitives for the Decade Exchange platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@decade/eslint-config": "workspace:*",
    "@decade/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
