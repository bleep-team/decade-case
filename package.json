{
  "name": "decade-exchange",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "sandcastle": "pnpm install && tsx .sandcastle/run.ts",
    "sandcastle:build": "docker build --build-arg AGENT_UID=$(id -u) -t sandcastle:decade -f .sandcastle/Dockerfile .",
    "sandcastle:clean": "pnpm install && tsx .sandcastle/cleanup.ts",
    "prepare": "husky || true"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@modelcontextprotocol/sdk": "1.26.0"
    }
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "0.5.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@decade/eslint-config": "workspace:*",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.4",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
